diff --git a/client/resource.ts b/client/resource.ts
index 89f05c7..69a8f6d 100644
--- a/client/resource.ts
+++ b/client/resource.ts
@@ -887,6 +887,27 @@ export class Resources {
         return { originalNetworkId, transportStreamId, serviceId };
     }
 
+    // component_ref (TR-B14 第二分冊 5.14.7.1): arib://<original_network_id>.<transport_stream_id>.<service_id>/<component_tag>
+    public parseComponentReference(componentRef: string): { originalNetworkId: number | null, transportStreamId: number | null, serviceId: number | null, component: string | null } {
+        const groups = /^arib:\/\/(?<originalNetworkId>[0-9a-f]+|-1)\.(?<transportStreamId>[0-9a-f]+|-1)\.(?<serviceId>[0-9a-f]+|-1)\/(?<component>[0-9a-f]+)$/i.exec(componentRef)?.groups;
+        if (groups == null) {
+            return { originalNetworkId: null, transportStreamId: null, serviceId: null, component: null };
+        }
+        let originalNetworkId: number | null = Number.parseInt(groups.originalNetworkId, 16);
+        let transportStreamId: number | null = Number.parseInt(groups.transportStreamId, 16);
+        let serviceId: number | null = Number.parseInt(groups.serviceId, 16);
+        if (originalNetworkId == -1) {
+            originalNetworkId = this.originalNetworkId;
+        }
+        if (transportStreamId == -1) {
+            transportStreamId = this.transportStreamId;
+        }
+        if (serviceId == -1) {
+            serviceId = this.serviceId;
+        }
+        return { originalNetworkId, transportStreamId, serviceId, component: groups.component };
+    }
+
