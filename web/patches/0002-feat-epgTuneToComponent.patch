+    function* epgTuneToComponent(component_ref: string) {
+        browserLog("%cepgTuneToComponent", "font-size: 4em", component_ref);
+        const { originalNetworkId, transportStreamId, serviceId, component } = resources.parseComponentReference(component_ref);
